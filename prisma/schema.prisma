generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  notes     Note[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Note {
  id        Int      @id @default(autoincrement())
  title     String
  content   String   @db.Text
  noteDate  DateTime
  entryType String   @default("note")
  label     String?
  color     String?
  time      String?
  isStarred Boolean  @default(false)
  location  String   @default("All Docs")
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, noteDate])
  @@index([userId, entryType])
  @@map("notes")
}
